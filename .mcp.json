{
  "mcpServers": {
    "novanet": {
      "command": "novanet-mcp",
      "env": {
        "NOVANET_MCP_NEO4J_URI": "bolt://localhost:7687",
        "NOVANET_MCP_NEO4J_USER": "neo4j",
        "NOVANET_MCP_NEO4J_PASSWORD": "${NOVANET_PASSWORD}",
        "RUST_LOG": "novanet_mcp=info"
      }
    }
  }
}
